#!/bin/bash
#===============================================================================
# QuickSight Dashboard Deployment (Fixed)
#
# Sets up:
#   1. Athena views that power the dashboard visuals
#   2. QuickSight Athena data source
#   3. QuickSight datasets (one per view)
#   4. QuickSight dashboard template
#
# Prerequisites:
#   - QuickSight Enterprise or Standard edition activated in your AWS account
#   - The Glue tables (jobs, job_skills) already populated via the ETL pipeline
#
# Usage:
#   bash infrastructure/deploy_quicksight.sh
#   bash infrastructure/deploy_quicksight.sh --views-only   # just create Athena views
#===============================================================================
set -euo pipefail
if [[ -f .env ]]; then set -a; source .env; set +a; fi
BUCKET_NAME="${S3_BUCKET:?Set S3_BUCKET in .env or export it}"
REGION="${AWS_REGION:-us-east-1}"
DATABASE="${GLUE_DATABASE:-job_market_db}"
VIEWS_ONLY=false
for arg in "$@"; do
  case "${arg}" in
    --views-only) VIEWS_ONLY=true ;;
  esac
done
AWS_ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text)"
echo "==============================================="
echo "  QuickSight Dashboard Deployment"
echo "==============================================="
echo "  Account   : ${AWS_ACCOUNT_ID}"
echo "  Region    : ${REGION}"
echo "  Bucket    : ${BUCKET_NAME}"
echo "  Database  : ${DATABASE}"
echo ""

# ── Step 1: Create Athena Views ──────────────────────────────────────────────
echo "[1/4] Creating Athena views..."
VIEWS_FILE="visualization/quicksight/athena_views.sql"
if [[ ! -f "${VIEWS_FILE}" ]]; then
  echo "ERROR: ${VIEWS_FILE} not found." >&2
  exit 1
fi

# Fixed Python parser that properly strips comments and handles multi-statement SQL
python3 - "${VIEWS_FILE}" "${DATABASE}" "${BUCKET_NAME}" "${REGION}" <<'PYEOF'
import sys
import re
import boto3
import time

views_file, database, bucket, region = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]

with open(views_file) as f:
    content = f.read()

# Remove all SQL comments (-- style)
content_no_comments = re.sub(r'--[^\n]*\n', '\n', content)

# Split on CREATE OR REPLACE VIEW, keeping the delimiter
statements = []
parts = re.split(r'(CREATE\s+OR\s+REPLACE\s+VIEW)', content_no_comments, flags=re.IGNORECASE)

i = 1
while i < len(parts):
    if re.match(r'CREATE\s+OR\s+REPLACE\s+VIEW', parts[i], re.IGNORECASE):
        # Combine the CREATE OR REPLACE VIEW with the following content
        stmt = parts[i]
        if i + 1 < len(parts):
            stmt += parts[i + 1]
        # Clean up: remove trailing semicolons and whitespace
        stmt = stmt.strip().rstrip(';').strip()
        if stmt:
            statements.append(stmt)
        i += 2
    else:
        i += 1

athena = boto3.client("athena", region_name=region)
output_loc = f"s3://{bucket}/athena-results/"

success_count = 0
error_count = 0

for stmt in statements:
    # Extract view name for logging
    match = re.search(r'VIEW\s+(\S+)\s+AS', stmt, re.IGNORECASE)
    view_name = match.group(1) if match else "unknown"
    print(f"  Creating view: {view_name}")
    
    try:
        response = athena.start_query_execution(
            QueryString=stmt,
            ResultConfiguration={"OutputLocation": output_loc}
        )
        query_id = response["QueryExecutionId"]
        
        # Wait for completion
        for _ in range(30):  # max 30 seconds
            status = athena.get_query_execution(QueryExecutionId=query_id)
            state = status["QueryExecution"]["Status"]["State"]
            if state in ("SUCCEEDED", "FAILED", "CANCELLED"):
                break
            time.sleep(1)
        
        if state == "SUCCEEDED":
            print(f"    OK")
            success_count += 1
        else:
            reason = status["QueryExecution"]["Status"].get("StateChangeReason", "Unknown error")
            print(f"    ERROR: {state} - {reason[:100]}")
            error_count += 1
            
    except Exception as e:
        print(f"    ERROR: {str(e)[:100]}")
        error_count += 1

print(f"  Done: {success_count} views created, {error_count} errors.")
PYEOF

if [[ "${VIEWS_ONLY}" == true ]]; then
  echo ""
  echo "Views created. Skipping QuickSight setup (--views-only)"
  exit 0
fi

# ── Step 2: Create QuickSight Data Source ────────────────────────────────────
echo ""
echo "[2/4] Creating QuickSight Athena data source..."
DS_ID="job-market-athena-ds"

# Check if data source exists
if aws quicksight describe-data-source \
    --aws-account-id "${AWS_ACCOUNT_ID}" \
    --data-source-id "${DS_ID}" \
    --region "${REGION}" >/dev/null 2>&1; then
  echo "  Data source already exists, skipping..."
else
  aws quicksight create-data-source \
    --aws-account-id "${AWS_ACCOUNT_ID}" \
    --data-source-id "${DS_ID}" \
    --name "Job Market Athena" \
    --type ATHENA \
    --data-source-parameters "AthenaParameters={WorkGroup=primary}" \
    --permissions "[{\"Principal\":\"arn:aws:quicksight:${REGION}:${AWS_ACCOUNT_ID}:user/default/$(aws sts get-caller-identity --query Arn --output text | cut -d'/' -f2)\",\"Actions\":[\"quicksight:DescribeDataSource\",\"quicksight:DescribeDataSourcePermissions\",\"quicksight:PassDataSource\",\"quicksight:UpdateDataSource\",\"quicksight:DeleteDataSource\",\"quicksight:UpdateDataSourcePermissions\"]}]" \
    --region "${REGION}" || echo "  Warning: Could not create data source (may need QuickSight setup)"
fi

# ── Step 3: Create QuickSight Datasets ───────────────────────────────────────
echo ""
echo "[3/4] Creating QuickSight datasets..."

VIEWS=(
  "vw_top_skills"
  "vw_skill_trends"
  "vw_salary_by_country"
  "vw_skill_growth"
  "vw_emerging_skills"
  "vw_skill_cooccurrence"
  "vw_dashboard_kpis"
  "vw_skills_by_category"
)

for view in "${VIEWS[@]}"; do
  DATASET_ID="job-market-${view}"
  echo "  Creating dataset: ${DATASET_ID}"
  
  # Skip if exists
  if aws quicksight describe-data-set \
      --aws-account-id "${AWS_ACCOUNT_ID}" \
      --data-set-id "${DATASET_ID}" \
      --region "${REGION}" >/dev/null 2>&1; then
    echo "    Already exists, skipping..."
    continue
  fi
  
  aws quicksight create-data-set \
    --aws-account-id "${AWS_ACCOUNT_ID}" \
    --data-set-id "${DATASET_ID}" \
    --name "Job Market - ${view}" \
    --import-mode DIRECT_QUERY \
    --physical-table-map "{\"${view}\":{\"RelationalTable\":{\"DataSourceArn\":\"arn:aws:quicksight:${REGION}:${AWS_ACCOUNT_ID}:datasource/${DS_ID}\",\"Catalog\":\"AwsDataCatalog\",\"Schema\":\"${DATABASE}\",\"Name\":\"${view}\",\"InputColumns\":[]}}}" \
    --region "${REGION}" 2>/dev/null || echo "    Warning: Could not create dataset"
done

# ── Step 4: Summary ──────────────────────────────────────────────────────────
echo ""
echo "[4/4] Deployment complete!"
echo ""
echo "  Next steps:"
echo "    1. Open QuickSight: https://${REGION}.quicksight.aws.amazon.com/"
echo "    2. Create analyses using the datasets created above"
echo "    3. Build dashboards with charts for skill trends, salaries, etc."
echo ""