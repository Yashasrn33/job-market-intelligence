# ──────────────────────────────────────────────────────────────
# Job Market Intelligence — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is git-ignored and will be auto-sourced by
# setup.sh, run_pipeline.sh, and deploy_ml.sh.
# ──────────────────────────────────────────────────────────────

# ── AWS Configuration ────────────────────────────────────────
# Region for all AWS resources (S3, Lambda, Glue, Athena, SageMaker)
AWS_REGION=us-east-1

# S3 bucket name — created by setup.sh if it doesn't exist.
# Must be globally unique. Leave blank to auto-generate during setup.
S3_BUCKET=

# ── Adzuna API ───────────────────────────────────────────────
# Sign up at https://developer.adzuna.com to get credentials.
# These are also stored in Secrets Manager by setup_aws.sh.
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here

# ── Glue / Athena ────────────────────────────────────────────
# Glue catalog database name (created by setup_aws.sh)
GLUE_DATABASE=job_market_db

# ── ML / Model ───────────────────────────────────────────────
# Local directory for trained model artifacts
MODEL_DIR=ml/models
